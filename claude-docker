#!/usr/bin/env bash
set -e

cd "$(dirname "$0")"

# Поднять контейнер если не запущен
docker compose up -d --wait 2>/dev/null || docker compose up -d

# --resume и --continue требуют TTY (интерактивный режим)
case "${1:-}" in
    --resume|--continue)
        docker compose exec -it -u claude claude claude "$@"
        ;;
    "")
        docker compose exec -it -u claude claude claude
        ;;
    *)
        docker compose exec -T -u claude claude claude "$@"
        ;;
esac
